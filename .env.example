# ─────────────────────────────────────────────────────────────────────────────
# Plantilla de variables de entorno. Copia a `.env` y rellena los valores.
# NO comitees `.env` (está en .gitignore). Detalle completo en DEPLOY.md.
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos (Postgres / Neon) ──────────────────────────────────────────
# Runtime (app y Vercel): usa la conexión POOLED de Neon (host `...-pooler...`).
# Migraciones (prisma migrate deploy): usa la conexión DIRECTA (sin `-pooler`).
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ── Better Auth ──────────────────────────────────────────────────────────────
# Secreto de firma de sesiones. Genera uno: `openssl rand -base64 32`.
BETTER_AUTH_SECRET="genera-un-secreto-largo-y-aleatorio"
# URL base del sitio. Local: http://localhost:3000
# Producción/demo: https://nayoli-demo.duna.solutions
BETTER_AUTH_URL="http://localhost:3000"

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Requeridas para enviar invitaciones al panel. Sin ellas, en dev se loguea el
# enlace en consola; en producción la invitación falla (500).
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
# Remitente en un dominio verificado en Resend.
EMAIL_FROM="Café Nayoli <no-reply@duna.solutions>"

# ── Seed del demo (SOLO al correr `prisma db seed`; NO se ponen en Vercel) ────
# Sin estas, el seed crea el OWNER con credenciales PÚBLICAS por defecto
# (admin@sierranativa.co / ChangeMe123!). Defínelas para un demo seguro.
ADMIN_EMAIL="owner@tu-dominio.com"
ADMIN_PASSWORD="una-contraseña-fuerte"
ADMIN_NAME="Administrador"

# ── WhatsApp (Twilio) — OPCIONAL ─────────────────────────────────────────────
# Solo si activas las automatizaciones de WhatsApp (vienen inactivas en el demo).
# El cliente se construye de forma perezosa: si faltan, no rompe nada al importar.
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
