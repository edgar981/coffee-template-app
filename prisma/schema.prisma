generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime  @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model user {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          Role      @default(STAFF)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  account       account[]
  session       session[]
}

model verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model Invitation {
  id        String    @id @default(cuid())
  email     String
  name      String?
  role      Role
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

enum Role {
  OWNER    // client (restaurant owner) - full access
  MANAGER  // their manager - most access
  STAFF    // waiter/delivery - limited access
}

model Customer {
  id              String   @id @default(cuid())
  nombre          String
  email           String?  @unique
  telefono        String?
  ciudad          String?
  direccion       String?
  canal           String?  @default("directo")
  notas           String?
  activo          Boolean  @default(true)
  numero_ordenes  Int      @default(0)
  total_compras   Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Product {
  id           String   @id @default(cuid())
  nombre       String
  slug         String   @unique
  descripcion  String   @default("")
  categoria    String
  precio       Float    @default(0)
  costo        Float    @default(0)
  sku          String?  @unique
  stock        Int      @default(0)
  stock_minimo Int      @default(5)
  activo       Boolean  @default(true)
  peso_gramos  Int?
  variante     String?
  origen       String?
  tostado      String?
  // Ficha técnica estructurada (empaque real) — editable desde el admin.
  // La tostión reutiliza el campo `tostado` existente (no se duplica).
  variedad     String?
  proceso      String?
  altitudMin   Int?
  altitudMax   Int?
  // Molienda del producto (p. ej. "Media") — solo variantes molidas; null en grano.
  molienda     String?
  // Opciones de molienda que ve el cliente en la página de producto:
  // [{ nombre: "Media", metodo: "Filtro / Greca tradicional", disponible: true }, …]
  // El admin activa nuevas moliendas cambiando `disponible` — sin cambios de código.
  moliendasOpciones Json?
  notasCata    String[] @default([])
  // Tags cortos del card del catálogo (p. ej. "Chocolate" · "Herbal").
  notas        String[] @default([])
  // Copy corto para el card del catálogo (la `descripcion` es la larga del detalle).
  descripcionCorta String?
  imagen       String   @default("")
  imagenes     String[] @default([])
  bestseller   Boolean  @default(false)
  badge        String?
  agotado      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orderItems   OrderItem[]
}

model Order {
  id                 String      @id @default(cuid())
  numero_orden       String      @unique
  // Client-generated key that makes order creation idempotent: a double submit or
  // network retry reuses the same key and returns the existing order instead of
  // creating a duplicate. Nullable + unique (Postgres allows many NULLs), so
  // legacy and checkout orders without a key are unaffected.
  idempotencyKey     String?     @unique
  cliente_nombre     String?
  cliente_email      String?
  cliente_telefono   String?
  canal              String      @default("directo")
  estado             String      @default("pendiente")
  metodo_pago        String?
  total              Float       @default(0)
  costo_envio        Float       @default(0)
  direccion_entrega  String?
  direccion_detalle  String?
  ciudad_entrega     String?
  notas_internas     String?
  notas_entrega      String?
  deliverySlot       String?
  items              OrderItem[]
  payments           Payment[]
  shipping           Shipping?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
}

model OrderItem {
  id               String   @id @default(cuid())
  orden_id         String
  producto_id      String?
  producto_nombre  String
  // Molienda elegida por el cliente al comprar (snapshot, p. ej. "Media").
  moliendaSeleccionada String?
  cantidad         Int
  precio_unitario  Float?
  subtotal         Float
  order            Order    @relation(fields: [orden_id], references: [id], onDelete: Cascade)
  product          Product? @relation(fields: [producto_id], references: [id])
}

model InventoryLog {
  id               String   @id @default(cuid())
  producto_id      String
  producto_nombre  String
  tipo             String
  cantidad         Int
  stock_anterior   Int
  stock_nuevo      Int
  motivo           String?
  createdAt        DateTime @default(now())
}

// A Payment is an event OF an Order: created when the admin registers a received
// payment, moving the order to `pagado` in the SAME transaction. `monto` is a
// snapshot of the order total at registration time (never typed by hand); the
// customer is read live through the relation. There is no payment `estado` — a
// row's existence IS the received payment; pending/paid lives on the Order.
model Payment {
  id                    String     @id @default(cuid())
  orden_id              String
  order                 Order      @relation(fields: [orden_id], references: [id], onDelete: Cascade)
  monto                 Float
  metodo                MetodoPago
  referencia            String?
  notas                 String?
  // Who registered it (admin session). Snapshotted so it survives user deletion.
  registrado_por        String?
  registrado_por_nombre String?
  // Business payment date (defaults to registration). `createdAt` is the audit ts.
  fecha                 DateTime   @default(now())
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@index([orden_id])
}

// Manual payment methods. Extensible for online rails later (e.g. WOMPI) via
// `ALTER TYPE "MetodoPago" ADD VALUE 'WOMPI'`.
enum MetodoPago {
  NEQUI
  DAVIPLATA
  EFECTIVO
  TRANSFERENCIA
  OTRO
}

model Shipping {
  id               String   @id @default(cuid())
  // One Shipping per Order (1:1). Auto-created in `preparando` when the order is
  // paid. Number, customer AND address are read live via the relation — the
  // Shipping keeps no copy of them. Only costo_envio is snapshotted (below).
  orden_id         String   @unique
  order            Order    @relation(fields: [orden_id], references: [id], onDelete: Cascade)
  // Zona and courier start empty; the operator fills them when scheduling.
  zona             String?
  estado           String   @default("preparando")
  costo_envio      Float    @default(0)
  mensajero        String?
  notas_entrega    String?
  fecha_programada String?
  fecha_entrega    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Automation {
  id               String   @id @default(cuid())
  tipo             String   @unique
  nombre           String
  canal            String
  activa           Boolean  @default(false)
  veces_ejecutada  Int      @default(0)
  ultima_ejecucion DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  tipo      String   // 'stock_bajo', 'nueva_orden', etc.
  titulo    String
  mensaje   String
  leida     Boolean  @default(false)
  href      String?  // optional link to relevant page
  createdAt DateTime @default(now())
}